{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "timezone": "UTC",
  "schedule": [
    "before 3am on Monday"
  ],
  "kubernetes": {
    "enabled": true
  },
  "docker": {
    "enabled": true,
    "automerge": false
  },
  "ignorePaths": [
    "ansible/**",
    "terraform/**"
  ],
  "packageRules": [
    {
      "description": "Group all image updates together",
      "matchDatasources": ["docker"],
      "groupName": "App Container Images",
      "groupSlug": "app-images"
    },
    {
      "description": "Update busybox and other utility images separately",
      "matchPackageNames": ["busybox"],
      "groupName": "Utility Images",
      "groupSlug": "utility-images"
    }
  ],
  "prConcurrentLimit": 2,
  "semanticCommits": "enabled",
  "labels": ["renovate"],
  "assignees": ["alfiemellor"]
}
