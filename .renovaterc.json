{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":enableVulnerabilityAlerts"
  ],
  "timezone": "UTC",
  "schedule": [
    "before 3am on Monday"
  ],
  "kubernetes": {
    "enabled": true
  },
  "docker": {
    "enabled": true,
    "automerge": false,
    "minimumReleaseAge": "7 days"
  },
  "registryAliases": {
    "ghcr": "ghcr.io",
    "docker": "docker.io"
  },
  "ignorePaths": [
    "ansible/**",
    "terraform/**",
    ".github/**"
  ],
  "packageRules": [
    {
      "description": "Group all image updates together",
      "matchDatasources": ["docker"],
      "groupName": "App Container Images",
      "groupSlug": "app-images",
      "schedule": [
        "before 3am on Monday"
      ]
    },
    {
      "description": "Update busybox and other utility images separately",
      "matchPackageNames": ["busybox"],
      "groupName": "Utility Images",
      "groupSlug": "utility-images"
    },
    {
      "description": "Require approval for major version bumps",
      "matchUpdateTypes": ["major"],
      "assignees": ["@alfiemellor"],
      "reviewers": ["@alfiemellor"]
    },
    {
      "description": "Auto-merge pre-release and patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "labels": ["renovate/patch"]
    }
  ],
  "prConcurrentLimit": 2,
  "prCreationLimit": 1,
  "semanticCommits": "enabled",
  "labels": ["renovate"],
  "assignees": ["alfiemellor"],
  "reviewers": ["alfiemellor"]
}
